# ── CI Report Generator — credentials ────────────────────────────────────────
#
# Copy this file to .env and fill in the values.
# Add .env to your .gitignore — never commit actual secrets.
#
# Pass to Docker with:  docker run --env-file .env ...
# Pass to Python with:  export $(grep -v '^#' .env | xargs) && python generate_report.py ...
# ─────────────────────────────────────────────────────────────────────────────

# JIRA (required when using --jira)
# Cloud:  base64-encoded "email@org.com:api_token"  (generate at id.atlassian.net/manage-profile/security/api-tokens)
# Server: raw personal access token
JIRA_API_TOKEN=

# Anthropic (required when using --ai)
# Generate at console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Add credentials for future tools below ────────────────────────────────────

# Example: read-only PostgreSQL access for a metrics tool
# DB_HOST=metrics.internal
# DB_PORT=5432
# DB_USER=ci_readonly
# DB_PASSWORD=

# Example: Artifactory API key for an artifact stats tool
# ARTIFACTORY_TOKEN=
