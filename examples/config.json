{
  "_comment": "Project config for generate_report.py. Use {build} as a placeholder for the build name passed on the CLI.",

  "credentials": {
    "_comment": "Env var names only — actual values belong in the environment, never in this file. Run --check-credentials to validate before a pipeline run.",
    "JIRA_API_TOKEN":    "JIRA service-account API token (base64 email:token for Cloud, Bearer for Server)",
    "ANTHROPIC_API_KEY": "Anthropic API key for AI analysis phase"
  },

  "base": {
    "build_url":     "https://ci.example.com/jobs/{build}",
    "branch":        "feature/chunked-upload",
    "branch_url":    "",
    "commit":        "",
    "commit_url":    "",
    "ref_build":     "1244",
    "ref_build_url": "https://ci.example.com/jobs/1244",
    "duration":      "",
    "badges": {
      "passed":  0,
      "skipped": 0,
      "metrics": 18
    }
  },

  "mysql": {
    "_note":              "Full data source — always collects failures (test_runs) and performance (performance_metrics). Load fixture: mysql < examples/fixtures/mysql_schema.sql",
    "host":               "localhost",
    "port":               3306,
    "database":           "ci_reports",
    "user_env":           "MYSQL_USER",
    "password_env":       "MYSQL_PASSWORD",
    "build":              "{build}",
    "ref_build":          "1244",
    "history_limit":      7,
    "perf_history_limit": 8,
    "jira_base_url":      "https://jira.example.com/browse/",
    "task_base_url":      "https://ci.example.com/jobs/{build}/tasks/",
    "log_base_url":       "https://ci.example.com/jobs/{build}/logs/",
    "fetch_logs":            false,
    "log_dest_dir":          "logs/{build}/mysql/",
    "log_parallel_requests": 8,
    "log_tail_bytes":        0,
    "log_skip_if_present":   true,
    "log_auth_token_env":    "CI_ARTIFACT_TOKEN"
  },

  "clickhouse": {
    "_note":              "Full data source — always collects failures (test_runs) and performance (performance_metrics). Load fixture: clickhouse-client --multiquery < examples/fixtures/clickhouse_schema.sql",
    "host":               "localhost",
    "port":               9000,
    "database":           "ci_metrics",
    "user_env":           "CLICKHOUSE_USER",
    "password_env":       "CLICKHOUSE_PASSWORD",
    "build":              "{build}",
    "ref_build":          "1244",
    "history_limit":      7,
    "perf_history_limit": 8,
    "jira_base_url":      "https://jira.example.com/browse/",
    "task_base_url":      "https://ci.example.com/jobs/{build}/tasks/",
    "log_base_url":       "https://ci.example.com/jobs/{build}/logs/",
    "fetch_logs":            false,
    "log_dest_dir":          "logs/{build}/clickhouse/",
    "log_parallel_requests": 8,
    "log_tail_bytes":        0,
    "log_skip_if_present":   true,
    "log_auth_token_env":    "CI_ARTIFACT_TOKEN"
  },

  "jira": {
    "base_url":          "https://your-org.atlassian.net",
    "email":             "ci-bot@your-org.com",
    "api_token_env":     "JIRA_API_TOKEN",
    "project_keys":      ["PIPE", "INFRA"],
    "max_related":       4,
    "search_terms":      3,
    "skip_if_present":   true,
    "timeout":           10,
    "parallel_requests": 8,
    "_note":             "Set JIRA_API_TOKEN env var before using --jira. parallel_requests=8 is safe under JIRA Cloud's 10 req/s rate limit."
  },

  "ai": {
    "model":             "claude-sonnet-4-6",
    "context_file":      "examples/context.txt",
    "log_dir":           "examples/logs/",
    "max_tokens":        600,
    "skip_if_present":   true,
    "parallel_requests": 4,
    "_note":             "Set ANTHROPIC_API_KEY env var before using --ai. Tune parallel_requests to your API tier's RPM limit."
  }
}
